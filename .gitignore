# --- pipeline data & outputs (regenerated; not version-controlled) ---
# Keep the results/ and logs/ dirs themselves (SLURM needs logs/ to exist
# before a job starts) but ignore their contents.
data/
results/*
!results/.gitkeep
logs/*
!logs/.gitkeep

# --- python ---
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
build/
dist/

# --- virtual environments ---
.venv/
venv/
env/
ENV/

# --- notebooks ---
.ipynb_checkpoints/

# --- editors / OS ---
.DS_Store
.idea/
.vscode/

# --- Claude Code local config ---
.claude/
*.pt
*.joblib
*.npz
results/checkpoints/
*.pt
*.joblib
*.npz
